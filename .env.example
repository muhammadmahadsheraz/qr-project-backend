PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/qr-app?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Email Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# OTP Configuration
OTP_EXPIRES_IN=10
